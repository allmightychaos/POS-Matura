<Window x:Class="Waldwunder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Waldwunder"
        mc:Ignorable="d"
        Title="MainWindow" Height="717" Width="1698">
    <DockPanel>
        <!-- Menüleiste -->
        <Menu DockPanel.Dock="Top" Name="Menu">
            <MenuItem Header="_Datei">
                <MenuItem Header="_Neues Waldwunder" Click="NeuesWwunder_Click"/>
                <MenuItem Header="_Waldwunder suchen" Click="WwunderSuchen_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="6*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Suchen" 
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               FontWeight="Bold" FontSize="18"
                               />

                    <Label Grid.Row="1" Grid.Column="0" Content="Stichwort:" VerticalAlignment="Center" FontSize="18"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="5" x:Name="StichwortBox"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Art:" VerticalAlignment="Center" FontSize="18"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="ArtBox"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="Ort" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="18" FontWeight="Medium"/>

                    <Grid Grid.Row="4" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="Lat:" VerticalAlignment="Center" FontSize="18"/>
                        <TextBox Grid.Column="1" Margin="5" x:Name="LatBox"/>

                    </Grid>

                    <Grid Grid.Row="4" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="Long:" VerticalAlignment="Center" FontSize="18"/>
                        <TextBox Grid.Column="1" Margin="5" x:Name="LongBox"/>

                    </Grid>
                    
                </Grid>
                
                <!-- Listbox -->
                <ListBox Grid.Row="1" ItemsSource="{Binding WaldwunderListe}" x:Name="WwunderListbox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" 
                        Content="Anzeigen" 
                        Margin="5"
                        FontSize="18"
                        Click="Anzeige_Click"
                        />

            </Grid>
            
            
            <!-- Karte -->
            <Grid Grid.Column="1" MouseDown="Grid_MouseDown">
                <Image Source="/images/Waldwunder-Karte.png" Margin="2"/>
                <Canvas x:Name="KarteCanvas" ClipToBounds="True"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
