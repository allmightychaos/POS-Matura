<Window x:Class="Osterhasen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Osterhasen"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Datenfelder-->
        <Grid Grid.Column="0">
            <!-- Person einfügen -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Column="1" Margin="5">
                <Label Content="Name:"/>
                <TextBox x:Name="NameBox" Height="30"
                          VerticalContentAlignment="Center"
                          Text="Bahnhof Wiener Neustadt"
                          />    

                <Label Content="Longitude:" Margin="0 10 0 0"/>
                <TextBox x:Name="LngBox" Height="30"
                          VerticalContentAlignment="Center"
                          Text="16.2351"
                          />

                <Label Content="Latitude:" Margin="0 10 0 0"/>
                <TextBox x:Name="LatBox" Height="30"
                          VerticalContentAlignment="Center"
                          Text="47.8118"
                          />

                <Button Content="Person erstellen" Margin="0 20 0 0" 
                        Height="30" Click="Button_Click"/>

                <Label Content="Person erfolgreich erstellt."
                        x:Name="Status"
                        Visibility="Hidden"
                        Foreground="MediumSeaGreen"
                        HorizontalContentAlignment="Center"
                        />
            </StackPanel>
            
            
            <!-- Helfer wählen -->
            <StackPanel Grid.Row="1" Margin="5">
                <Label Content="Helfer-Anzahl:" Margin="0 10 0 0"/>
                <TextBox x:Name="HelferBox" Height="30"
                          VerticalContentAlignment="Center"
                          Text="4"
                          />

                <Button Content="Auswählen" Height="30" Click="Button_Click_1"/>
            </StackPanel>
            
        </Grid>
        
       
        
        <!-- Wr. Neustadt Karte -->
        <Grid Grid.Column="1">
            <Image Name="Karte" Source="/Stadtplan-Wiener-Neustadt.jpg" Stretch="Uniform"/>
            <Canvas Width="{Binding ElementName=Karte, Path=ActualWidth}"
                    Height="{Binding ElementName=Karte, Path=ActualHeight}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ClipToBounds="True"
                    x:Name="KarteCanvas"
                    />
        </Grid>
    </Grid>
</Window>
