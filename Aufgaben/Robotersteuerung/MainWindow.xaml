<Window x:Class="Robotersteuerung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Robotersteuerung"
        xmlns:roboter="clr-namespace:AbcRobotCore;assembly=AbcRobotCore"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_XML laden" Click="XMLaden_Click"/>
            <MenuItem Header="_Anweisungen laden" Click="TXTLaden_Click"/>
        </Menu>
        
        <roboter:RobotField x:Name="Field"/>
    </DockPanel>
</Window>
