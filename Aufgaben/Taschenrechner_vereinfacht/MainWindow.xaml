<Window x:Class="Taschenrechner_vereinfacht.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Taschenrechner_vereinfacht"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="5">
            <Label     Margin="2" Content="Eingabe:"/>
            <TextBox   Margin="2" x:Name="Box" Height="30" Width="200" HorizontalAlignment="Left"/>
            <Button    Margin="2" Content="Validieren" Height="30" Width="200" HorizontalAlignment="Left" Click="Button_Click"/>
            <TextBlock Margin="2 10" x:Name="Block" Height="30" Width="200" HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Window>
