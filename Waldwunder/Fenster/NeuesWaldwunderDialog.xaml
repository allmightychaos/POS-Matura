<Window x:Class="Waldwunder.Fenster.NeuesWaldwunderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Waldwunder.Fenster"
        mc:Ignorable="d"
        Title="Neues Waldwunder" Height="450" Width="600">
    <Grid>
        <!-- Grid-Definitions -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="13*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- ================================================== -->
        
        <!-- Titel-->
        <TextBlock Grid.Column="0" Grid.Row="0" 
                   Text="Waldwunder Daten" 
                   FontWeight="Bold" FontSize="18"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   />

        <TextBlock Grid.Column="1" Grid.Row="0" 
                   Text="Bilder" 
                   FontWeight="Bold" FontSize="18"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   />

        <!-- Waldwunder Daten-->
        <Grid Grid.Column="0" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Name:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="NameBox"/>
            </Grid>

            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Beschreibung:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="BeschreibungBox"/>
            </Grid>

            <Grid Grid.Row="2" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Provinz:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="ProvinzBox"/>
            </Grid>

            <Grid Grid.Row="3" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Lat:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="LatBox"/>
            </Grid>

            <Grid Grid.Row="4" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Long:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="LongBox"/>
            </Grid>

            <Grid Grid.Row="5" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Art:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="ArtBox"/>
            </Grid>

            <Grid Grid.Row="6" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Stimmen:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="StimmenBox"/>
            </Grid>
        </Grid>

        
        <!-- Bilder -->
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Margin="5" Content="Bilder laden" 
                    Click="BilderLaden_Click"/>

            <ListBox Grid.Row="1" 
                     Margin="5" 
                     Name="BilderListbox" 
                     SelectionMode="Multiple"
                     ItemsSource="{Binding ImagesList}"
                     >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>
        
        
        <!-- Registrieren Button -->
        <Button Grid.Row="2" Grid.Column="0"
                Content="Registrieren" 
                Margin="5 2" 
                Click="Registrieren_Click"/>
    
        <!-- Bilder entfernen Button -->
        <Button Grid.Row="2" Grid.Column="1"
                Content="Bild(er) entfernen"
                Margin="5 2"
                Click="BilderEntfernen_Click"
                />
    </Grid>
    
</Window>
